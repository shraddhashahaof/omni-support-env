# Virtual environments — never commit these
venv/
env/
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment variables — never commit secrets
.env

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/

# VS Code
.vscode/

# Build / distribution
dist/
build/
*.egg-info/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Local data / outputs
data/
omni-grpo-output/
outputs/

# Git internals (usually unnecessary but harmless to exclude patterns elsewhere)
*.tmp